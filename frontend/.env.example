# Leave unset for local development — Vite's dev-server proxy (see vite.config.js)
# forwards /api to http://localhost:5000 automatically.
#
# Set this when deploying frontend and backend on separate domains/hosts,
# e.g. frontend on Vercel/Netlify, backend on Railway/Render:
# VITE_API_URL=https://api.yourclinic.com/api
